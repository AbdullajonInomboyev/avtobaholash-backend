# ─── Django ───────────────────────────────────
SECRET_KEY=your-very-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=avtobaholash.uz,*.avtobaholash.uz

# ─── Database ─────────────────────────────────
DB_NAME=avtobaholash
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
# REDIS_URL avtomatik quriladi: redis://:password@host:port/0

# ─── MinIO (Fayl saqlash) ─────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=avtobaholash
MINIO_ENDPOINT=http://localhost:9000

# ─── AI ───────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6

# ─── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_WEBHOOK_URL=https://avtobaholash.uz/api/v1/telegram/webhook/

# ─── Email ────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@avtobaholash.uz
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=EduLens <noreply@avtobaholash.uz>

# ─── CORS ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://avtobaholash.uz,https://ttu.avtobaholash.uz
